APP_NAME=LeadBot
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=leadbot
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Instagram Scraper Credentials
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password
MAX_LEADS_PER_RUN=10
SCRAPER_HEADLESS=true

# Scraper path (absolute path to scraper.js)
SCRAPER_PATH=/home/md-limon-hossain/SAAS/LeadBot/scraper/scraper.js
NODE_BINARY=/usr/bin/node

# Admin credentials (used for seeder)
ADMIN_EMAIL=admin@leadbot.local
ADMIN_PASSWORD=Admin@12345
